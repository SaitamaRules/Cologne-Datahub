{
  "tasks": {
    "dev": "deno run --allow-net --allow-env --allow-read --watch src/main.ts",
    "start": "deno run --allow-net --allow-env --allow-read src/main.ts",
    "test": "deno test --allow-net --allow-env --allow-read",
    "fmt": "deno fmt",
    "fmt:check": "deno fmt --check",
    "lint": "deno lint",
    "check": "deno check src/main.ts"
  },
  "fmt": {
    "include": ["src/", "scripts/", "tests/"],
    "exclude": ["data/", "docs/openapi.json"],
    "lineWidth": 100,
    "indentWidth": 2,
    "semiColons": true,
    "singleQuote": false,
    "useTabs": false
  },
  "lint": {
    "include": ["src/", "scripts/", "tests/"],
    "exclude": ["data/"],
    "rules": {
      "tags": ["recommended"]
    }
  },
  "imports": {
    "hono": "npm:hono@4.5.4",
    "hono/": "npm:/hono@4.5.4/",
    "postgres": "https://deno.land/x/postgres@v0.19.3/mod.ts",
    "@std/dotenv": "jsr:@std/dotenv@^0.225.0",
    "mongo": "https://deno.land/x/mongo@v0.33.0/mod.ts",
    "proj4": "npm:proj4@^2.15.0"
  }
}
