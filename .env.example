# ---- PostgreSQL ----
DB_NAME=cologne_datahub
DB_USER=postgres
DB_PASSWORD=change-me-in-production
# DB_HOST / DB_PORT are injected by docker-compose.yml (postgres:5432)
# and only need to be set here for local Deno runs outside Docker.

# ---- MongoDB ----
# MONGO_URI is injected by docker-compose.yml (mongodb://mongo:27017).
# Only set it here for local Deno runs outside Docker.

# ---- API ----
# Used by the x-api-key middleware to authorise write operations.
# Generate something opaque, for example:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
API_KEY=change-me-in-production
