# ---- PostgreSQL ----
DB_NAME=cologne_datahub
DB_USER=postgres
DB_PASSWORD=change-me-in-production
# DB_HOST / DB_PORT are injected by docker-compose.yml as the FQDN
# `db-pg.cologne.local:5432`, resolved by the internal BIND9 server.
# Only set DB_HOST/DB_PORT here for local Deno runs outside Docker.

# ---- MongoDB ----
# MONGO_URI is injected by docker-compose.yml as
# `mongodb://db-mongo.cologne.local:27017`. Only set it here for local
# Deno runs outside Docker.

# ---- API ----
# Used by the x-api-key middleware to authorise write operations.
# Generate something opaque, for example:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
API_KEY=change-me-in-production
