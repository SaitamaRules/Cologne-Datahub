# Default: let git auto-detect text vs binary and normalize line endings
* text=auto

# Force LF for files that must have LF regardless of platform
Makefile   text eol=lf
*.sh       text eol=lf
*.yml      text eol=lf
*.yaml     text eol=lf

# Treat as binary (do not diff/merge as text)
*.png  binary
*.jpg  binary
*.pdf  binary
